# =============================================================================
# ZERO-CARD STACK — see docs/FREE_STACK.md
# Only Groq + Hugging Face need free API keys (no payment method).
# =============================================================================

# --- Required for real AI (free, no card) ---
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# --- Storage: local disk (default) or MinIO in Docker — NOT Cloudflare R2 ---
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# MinIO only if STORAGE_BACKEND=minio (docker compose minio service)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fashion-ai

# --- Database: SQLite default (no account). Or Postgres in docker-compose ---
DATABASE_URL=sqlite+aiosqlite:///./fashionai.db
REDIS_URL=redis://localhost:6379/0

# --- Vector DB: local Qdrant in Docker (no Qdrant Cloud account needed) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- LLM routing ---
LITELLM_PROXY_URL=http://localhost:4000
OLLAMA_BASE_URL=http://localhost:11434
LLM_PRIMARY_MODEL=groq/llama-3.3-70b-versatile
LLM_FAST_MODEL=groq/llama-3.1-8b-instant
LLM_FALLBACK_MODEL=ollama/llama3.2

# --- Inference ---
HF_INFERENCE_URL=https://api-inference.huggingface.co
WHISPER_MODEL=openai/whisper-large-v3
FASHIONCLIP_MODEL=patrickjohncyh/fashion-clip
SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_HOST=0.0.0.0
API_PORT=8000

# --- Auth: built-in guest JWT (no Supabase required) ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_USER_RPM=30
RATE_LIMIT_IP_RPM=100

# =============================================================================
# OPTIONAL — skip unless you verified NO CARD at signup
# =============================================================================

# Supabase (hosted Postgres/Auth — may ask for card in some regions)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# Observability clouds (use Prometheus in docker-compose instead)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# POSTHOG_API_KEY=
# SENTRY_DSN=

# Push notifications (requires Firebase/Google — optional)
# FCM_SERVER_KEY=

# Render deploy (optional; HF Spaces preferred — see deploy/huggingface/)
# RENDER_DEPLOY_HOOK_URL=
